[Unit]
Description=Black Mamba Relay Server
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/black-mamba-server
ExecStart=/usr/bin/node server/index.js
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment="NODE_ENV=production"
Environment="BLACK_MAMBA_HOST=0.0.0.0"
Environment="BLACK_MAMBA_PORT=8090"
Environment="BLACK_MAMBA_TTL_MS=600000"
Environment="BLACK_MAMBA_MAX_ROOMS=500"
Environment="BLACK_MAMBA_MAX_ROOM_SIZE=10"
Environment="BLACK_MAMBA_WEB_URL=http://13.53.212.66:8090"
Environment="BLACK_MAMBA_WS_URL_PUBLIC=ws://13.53.212.66:8090"

[Install]
WantedBy=multi-user.target
