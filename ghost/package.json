{
  "name": "onion-chat-mamba",
  "version": "1.3.5",
  "type": "module",
  "bin": {
    "black-mamba": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "logo.txt",
    "web"
  ],
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:cli": "tsx cli/index.ts",
    "build": "tsc -p tsconfig.json",
    "start:server": "node dist/server/index.js",
    "start:cli": "node dist/cli/index.js",
    "bundle": "pkg dist/bundle.cjs --out-path ./bin"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "socks-proxy-agent": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.24",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pkg": {
    "assets": [
      "logo.txt",
      "web/**/*",
      "dist/**/*",
      "node_modules/blessed/usr/**/*",
      "node_modules/ws/**/*",
      "node_modules/socks-proxy-agent/**/*",
      "node_modules/socks/**/*",
      "node_modules/ip-regex/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64"
    ]
  }
}
